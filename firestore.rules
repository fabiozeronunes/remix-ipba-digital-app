rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to identify the user's document ID from their email
    function getUserDocId(email) {
      return email.lower();
    }

    function isAdmin() {
      return isSignedIn() && 
             'email' in request.auth.token &&
             (
               request.auth.token.email.lower() == 'fabiozeronunes@gmail.com' ||
               (
                 exists(/databases/$(database)/documents/users/$(getUserDocId(request.auth.token.email))) &&
                 get(/databases/$(database)/documents/users/$(getUserDocId(request.auth.token.email))).data.category.matches('(?i).*(Pastor|Presb|Admin|Coordenador).*')
               )
             );
    }

    function isOwner(email) {
      return isSignedIn() && 
             'email' in request.auth.token &&
             email != null &&
             request.auth.token.email.lower() == email.lower();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // USERS
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && (('email' in request.auth.token && request.auth.token.email.lower() == resource.data.email.lower()) || isAdmin());
      allow delete: if isAdmin();
    }

    // PRAYERS
    match /prayers/{prayerId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin() || (isSignedIn() && isOwner(resource.data.authorEmail));
    }

    // CELLS
    match /cells/{cellId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // CONTRIBUTIONS
    match /contributions/{id} {
      allow read: if isSignedIn() && (isOwner(resource.data.userEmail) || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // EVENTS
    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
      // Allow users to confirm participation
      allow update: if isSignedIn();
    }

    // STUDIES & RADIO
    match /studies/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /radioPrograms/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // TRANSMISSIONS
    match /transmissions/{id} {
        allow read: if true;
        allow write: if isAdmin();
    }
    match /transmissionChats/{id} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isAdmin();
    }

    // SUPPORT
    match /supportOptions/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /supportTickets/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // NOTIFICATIONS
    match /notifications/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    
    // CUSTOM ROLES
    match /customRoles/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
