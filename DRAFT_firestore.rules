rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to check for email verification
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // Helper to identify the user's document ID from their email
    // This is a simplified version of the logic in getUserDocId
    // Since we can't easily perform the .replace(/[^a-z0-9_\-]/g, '_') in rules perfectly,
    // we assume the document ID was generated via the same logic.
    // For our comparison purposes, we check the 'email' field inside the doc if needed.
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.token.email.lower().replace('[^a-z0-9_\\-]', '_'))).data;
    }

    function isAdmin() {
      let category = getUserData().category;
      return category.contains('Pastor') || category.contains('Presbítero') || category.contains('Admin') || category.contains('Coordenador');
    }

    function isOwner(email) {
      return isSignedIn() && request.auth.token.email.lower() == email.lower();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // USERS
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.token.email.lower() == request.resource.data.email.lower();
      allow update: if (isSignedIn() && (request.auth.token.email.lower() == resource.data.email.lower() || isAdmin())) && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'phone', 'category', 'avatarUrl', 'birthDate', 'address', 'ministry', 'password', 'status', 'updatedAt'])
      );
      allow delete: if isAdmin();
    }

    // PRAYERS
    match /prayers/{prayerId} {
      allow read: if isSignedIn() && (resource.data.visibilidade == 'Público' || isAdmin() || isOwner(resource.data.authorEmail));
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        (isOwner(resource.data.authorEmail) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'description', 'visibilidade', 'updatedAt', 'userOred', 'count'])) ||
        (isAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['aprovado', 'visibilidade', 'updatedAt'])) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['count', 'userOred']))
      );
      allow delete: if isAdmin() || (isSignedIn() && isOwner(resource.data.authorEmail));
    }

    // CELLS
    match /cells/{cellId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // CONTRIBUTIONS
    match /contributions/{id} {
      allow read: if isSignedIn() && (isOwner(resource.data.userEmail) || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // EVENTS
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
      // Allow users to confirm participation
      allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['confirmedUsers', 'updatedAt']);
    }

    // STUDIES & RADIO
    match /studies/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /radioPrograms/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // TRANSMISSIONS
    match /transmissions/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /transmissionChats/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // SUPPORT
    match /supportOptions/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /supportTickets/{id} {
      allow read: if isSignedIn() && (isOwner(resource.data.email) || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // NOTIFICATIONS
    match /notifications/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // CUSTOM ROLES
    match /customRoles/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
